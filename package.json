    "eval:bid-generator": "tsx evals/scripts/run-bid-generator.ts",
    "eval:bid-compare": "tsx evals/scripts/run-bid-model-compare.ts",
    "eval:zero-halluc": "tsx evals/scripts/zero-hallucination-loop.ts",
    "eval:gen-cv-fixtures": "tsx evals/scripts/generate-cv-fixtures.ts",
    "template:introspect": "tsx scripts/introspect-template.ts",
    "gen:setup-sql": "tsx scripts/generate-setup-sql.ts",
    "doctor": "node --env-file-if-exists=.env.local node_modules/tsx/dist/cli.mjs scripts/doctor.ts",
    "calibrate:budgets": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/calibrate-budgets.ts",
    "calibrate:backfill-single-line": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/backfill-single-line.ts",
