# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TED radar (optional). The /api/radar/fetch and /api/radar/score cron
# endpoints reject all requests unless this is set and sent as
# "Authorization: Bearer <CRON_SECRET>". Leave unset to keep the radar
# background jobs disabled (they will 401).
# CRON_SECRET=generate-a-long-random-string
