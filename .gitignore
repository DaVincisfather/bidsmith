# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local scratch output (sample PPTX, scratch files)
/tmp
sample-output.pptx

# superpowers plugin state
.superpowers/

# local data (anonymized test files etc.)
/data

# local tech-stack illustrations (canonical version lives in README)
docs/tech-stack.html
docs/tech-stack.png

# eval runs (local outputs, not shared)
/evals/runs
.gstack/
